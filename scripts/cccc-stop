#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
CACHE_DIR="${HOME}/Library/Caches/cccc"
PID_FILE="${CACHE_DIR}/main.pid"
PORT="${CCCC_WEB_PORT:-8848}"

is_alive() {
  kill -0 "$1" 2>/dev/null
}

is_running() {
  local state

  if ! is_alive "$1"; then
    return 1
  fi

  state="$(ps -o state= -p "$1" 2>/dev/null | tr -d '[:space:]' | cut -c1)"
  [[ "${state}" != "Z" ]]
}

collect_descendants() {
  local pid="$1"
  local child

  while IFS= read -r child; do
    [[ -n "${child}" ]] || continue
    collect_descendants "${child}"
    printf '%s\n' "${child}"
  done < <(pgrep -P "${pid}" || true)
}

find_repo_pids() {
  ps -axo pid=,command= | awk -v repo="${REPO_DIR}" -v self="$$" '
    $1 != self && (index($0, repo "/.venv/bin/cccc") || /Python .* -m cccc\./) {
      print $1
    }
  '
}

load_repo_pids() {
  local pid
  FALLBACK_PIDS=()

  while IFS= read -r pid; do
    [[ -n "${pid}" ]] || continue
    FALLBACK_PIDS+=("${pid}")
  done < <(find_repo_pids)
}

stop_targets() {
  local forced=0
  local pid
  local any_alive=0
  local -a targets=()
  local -a descendants=()

  while IFS= read -r pid; do
    [[ -n "${pid}" ]] || continue
    descendants+=("${pid}")
  done < <(collect_descendants "$1")
  targets=("${descendants[@]}" "$1")

  is_running "$1" && kill "$1" 2>/dev/null || true

  for _ in {1..40}; do
    any_alive=0
    for pid in "${targets[@]}"; do
      if is_running "${pid}"; then
        any_alive=1
        break
      fi
    done
    [[ "${any_alive}" -eq 0 ]] && return 0
    sleep 0.5
  done

  for pid in "${descendants[@]}"; do
    is_running "${pid}" && kill "${pid}" 2>/dev/null || true
  done

  for _ in {1..10}; do
    any_alive=0
    for pid in "${targets[@]}"; do
      if is_running "${pid}"; then
        any_alive=1
        break
      fi
    done
    [[ "${any_alive}" -eq 0 ]] && return 0
    sleep 0.5
  done

  for pid in "${targets[@]}"; do
    if is_running "${pid}"; then
      kill -9 "${pid}" 2>/dev/null || true
      forced=1
    fi
  done

  sleep 0.5
  return "${forced}"
}

if [[ ! -f "${PID_FILE}" ]]; then
  load_repo_pids
  if [[ "${#FALLBACK_PIDS[@]}" -eq 0 ]]; then
    echo "CCCC is not running (no pid file)."
    exit 0
  fi

  for pid in "${FALLBACK_PIDS[@]}"; do
    stop_targets "${pid}" || true
  done
  echo "Stopped CCCC processes found without pid file."
  exit 0
fi

CCCC_PID="$(cat "${PID_FILE}")"
if [[ -z "${CCCC_PID}" ]]; then
  rm -f "${PID_FILE}"
  echo "Removed empty pid file."
  exit 0
fi

if ! kill -0 "${CCCC_PID}" 2>/dev/null; then
  rm -f "${PID_FILE}"
  load_repo_pids
  if [[ "${#FALLBACK_PIDS[@]}" -eq 0 ]]; then
    echo "Removed stale pid file for pid ${CCCC_PID}."
    exit 0
  fi

  for pid in "${FALLBACK_PIDS[@]}"; do
    stop_targets "${pid}" || true
  done
  echo "Removed stale pid file and stopped matching CCCC processes."
  exit 0
fi

rm -f "${PID_FILE}"
if stop_targets "${CCCC_PID}"; then
  STOP_RESULT=0
else
  STOP_RESULT=$?
fi

LISTENER_PID="$(lsof -tiTCP:${PORT} -sTCP:LISTEN 2>/dev/null || true)"
if [[ -n "${LISTENER_PID}" ]]; then
  kill -9 "${LISTENER_PID}" 2>/dev/null || true
  STOP_RESULT=1
fi

if [[ "${STOP_RESULT}" -eq 0 ]]; then
  echo "CCCC stopped."
else
  echo "CCCC stopped after forcing one or more child processes."
fi
